{
  "name": "nuxt-app",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.2.2+sha512.36e6621fad506178936455e70247b8808ef4ec25797a9f437a93281a020484e2607f6a469a22e982987c3dbb8866e3071514ab10a4a1749e06edcd1ec118436f",
  "engines": {
    "node": "22.22.1"
  },
  "scripts": {
    "prebuild": "node scripts/generate-project-images-map.js && node scripts/generate-gallery-images-map.js",
    "generate:metadata": "node scripts/generate-project-images-metadata.js",
    "test:prerender": "node scripts/test-prerender.js",
    "audit:seo": "pnpm build && node scripts/audit-seo.js",
    "audit:schema-org": "pnpm build && node scripts/audit-schema-org.js",
    "build": "nuxt build",
    "dev": "nuxt dev",
    "dev:netlify": "netlify dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare && (npx skilld prepare || true)",
    "typecheck": "vue-tsc --noEmit && vue-tsc --noEmit -p tests/tsconfig.json && pnpm typecheck:config",
    "typecheck:config": "vue-tsc --noEmit -p tsconfig.nuxt-config.json && vue-tsc --noEmit -p tsconfig.content-config.json",
    "lint": "NODE_OPTIONS=--no-warnings eslint .",
    "lint:fix": "NODE_OPTIONS=--no-warnings eslint . --fix",
    "lint:md": "remark . --use remark-preset-lint-recommended --quiet",
    "format:md": "remark . --output --quiet",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:build-output": "pnpm generate && AUDIT_BUILD_OUTPUT=1 vitest run tests/gallery-build-output.test.ts",
    "test:watch": "vitest",
    "sync:pnpm": "node scripts/sync-pnpm-version.js",
    "check:pnpm": "node scripts/sync-pnpm-version.js --check",
    "check": "pnpm check:pnpm && pnpm typecheck && pnpm lint && pnpm test:unit && pnpm test:build-output && pnpm test:prerender",
    "prepare": "husky && (npx skilld prepare || true)"
  },
  "dependencies": {
    "@headlessui/vue": "^1.7.23",
    "@intlify/shared": "^11.4.4",
    "@netlify/nuxt": "^0.3.6",
    "@nuxt/fonts": "^0.14.0",
    "@nuxtjs/i18n": "^10.3.0",
    "@takumi-rs/core": "^0.73.1",
    "better-sqlite3": "^12.10.0",
    "lightgallery": "^2.9.0",
    "minisearch": "^7.2.0",
    "nuxt": "^4.4.6",
    "ogl": "^1.0.11",
    "pixi.js": "^8.18.1",
    "reka-ui": "^2.9.7",
    "simplex-noise": "^4.0.3",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@barzhsieh/nuxt-content-mermaid": "2.2.3",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@formkit/auto-animate": "^0.9.0",
    "@iconify-json/devicon": "^1.2.62",
    "@iconify-json/iconoir": "^1.2.11",
    "@iconify-json/line-md": "^1.2.16",
    "@iconify-json/logos": "^1.2.11",
    "@iconify-json/lucide": "^1.2.108",
    "@iconify-json/material-symbols-light": "^1.2.73",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/radix-icons": "^1.2.6",
    "@iconify-json/ri": "^1.2.10",
    "@iconify-json/simple-icons": "^1.2.83",
    "@iconify-json/skill-icons": "^1.2.4",
    "@iconify-json/tabler": "^1.2.35",
    "@iconify-json/vscode-icons": "^1.2.50",
    "@nuxt/content": "^3.14.0",
    "@nuxt/icon": "^2.2.2",
    "@nuxt/image": "^2.0.0",
    "@nuxt/kit": "^4.4.6",
    "@nuxtjs/html-validator": "^2.1.0",
    "@nuxtjs/mdc": "^0.22.0",
    "@nuxtjs/robots": "6.0.8",
    "@nuxtjs/seo": "^5.1.3",
    "@nuxtjs/sitemap": "8.0.15",
    "@stefanobartoletti/nuxt-social-share": "^3.0.0",
    "@unocss/eslint-plugin": "^66.6.8",
    "@unocss/nuxt": "^66.6.8",
    "@vueuse/core": "^14.3.0",
    "@vueuse/nuxt": "^14.3.0",
    "dayjs": "^1.11.20",
    "eslint": "^10.4.0",
    "eslint-plugin-format": "^2.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "nitropack": "^2.13.4",
    "nuxt-delay-hydration": "^1.3.8",
    "nuxt-headlessui": "^1.2.2",
    "nuxt-og-image": "6.5.1",
    "nuxt-schema-org": "6.0.4",
    "remark-validate-links": "^13.1.0",
    "sass": "^1.99.0",
    "shiki": "^4.1.0",
    "swiper": "^12.1.4",
    "typescript": "^6.0.3",
    "unocss": "^66.6.8",
    "vitest": "^4.1.7",
    "vue-tsc": "^3.3.1",
    "yaml": "^2.9.0"
  },
  "lint-staged": {
    "*.{js,ts,vue}": "eslint --fix"
  },
  "volta": {
    "node": "22.22.1"
  }
}
