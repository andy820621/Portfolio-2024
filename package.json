    "minisearch": "^7.2.0",
    "nuxt": "^4.4.2",
    "ogl": "^1.0.11",
    "pixi.js": "^8.17.1",
    "reka-ui": "^2.9.5",
    "simplex-noise": "^4.0.3",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
