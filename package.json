    "@iconify-json/ri": "^1.2.10",
    "@iconify-json/simple-icons": "^1.2.77",
    "@iconify-json/skill-icons": "^1.2.4",
    "@iconify-json/tabler": "^1.2.33",
    "@iconify-json/vscode-icons": "^1.2.45",
    "@nuxt/content": "^3.12.0",
    "@nuxt/icon": "^2.2.1",
    "@nuxt/image": "^2.0.0",
    "@nuxt/kit": "^4.4.2",
    "@nuxtjs/html-validator": "^2.1.0",
    "@nuxtjs/mdc": "^0.20.2",
    "@nuxtjs/seo": "^5.1.3",
    "@stefanobartoletti/nuxt-social-share": "^2.3.1",
    "@unocss/eslint-plugin": "^66.6.8",
    "@unocss/nuxt": "^66.6.8",
    "@vueuse/core": "^14.2.1",
    "@vueuse/nuxt": "^14.2.1",
    "dayjs": "^1.11.20",
    "eslint": "^10.2.0",
    "eslint-plugin-format": "^2.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nuxt-delay-hydration": "^1.3.8",
    "nuxt-headlessui": "^1.2.2",
    "remark-validate-links": "^13.1.0",
    "sass": "^1.99.0",
    "swiper": "^12.1.3",
    "typescript": "^6.0.2",
